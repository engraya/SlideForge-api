# Copy this file to .env and fill in your values. Never commit .env.

# Required: Google Gemini API key
GOOGLE_API_KEY=your-google-api-key-here

# Runtime environment: development | staging | production
# In production: Swagger UI (/docs) is disabled automatically
ENVIRONMENT=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Directory where generated .pptx files are stored
OUTPUT_DIR=generated

# Maximum number of slides allowed per request (1-50)
MAX_SLIDES=20

# How long generated files are kept before cleanup (seconds)
FILE_TTL_SECONDS=3600

# Max API calls per IP per minute
RATE_LIMIT_PER_MINUTE=10

# Allowed CORS origins (JSON array)
CORS_ORIGINS=["http://localhost:3000","https://intelli-slide-ai.vercel.app"]
